# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=daily_sql

# Database URL (Used by the app to connect)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql://postgres:your_secure_password_here@dailysql-postgres:5432/daily_sql

# JWT Secret — generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# Google OAuth (get from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# URLs (used for OAuth redirect construction)
FRONTEND_URL=https://www.dailysql.in
BACKEND_URL=https://api.dailysql.in

# Admin Secret for backend endpoints
ADMIN_SECRET=your_admin_secret_key

# Redis URL (internal docker networking)
REDIS_URL=redis://dailysql-redis:6379/0

# CORS origins (comma-separated)
CORS_ORIGINS=https://www.dailysql.in,https://dailysql.in
